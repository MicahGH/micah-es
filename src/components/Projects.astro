---
const PROJECTS = [
    {
        title: 'Café EPOS Backend',
        description: 'A small implementation of the backend of a café EPOS system built for a technical test. Powered by Django, Django REST Framework, PostgreSQL, Poetry, and Docker.',
        github: 'https://github.com/MicahGH/cafe-epos',
        image: './projects/cafe_epos.jpg',
        tags: ['Python', 'Django', 'PostgreSQL', 'Poetry', 'Docker'],
    }
]
---

{
    PROJECTS.map(project => (
        <article>
            <h3 class="text-2xl font-semibold text-[#C9A227]">{project.title}</h3>
            <p>{project.description}</p>
            <ul>
                {project.tags.map(tag => (
                    <li>{tag}</li>
                ))}
            </ul>
            <img class="rounded shadow-2xl shadow-white/10" src={project.image} alt={`Screenshot of the project ${project.image}`}>
        </article>
    ))
}