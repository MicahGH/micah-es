---
import cafeEpos from "../assets/cafe_epos.jpg"

const PROJECTS = [
    {
        title: 'Café EPOS Backend',
        description: '',
        github: '',
        image: cafeEpos.src,
        tags: ['Python', 'Django', 'PostgreSQL', 'Poetry', 'Docker'],
    }
]
---

{
    PROJECTS.map(project => (
        <article>
            <h3>{project.title}</h3>
            <p>{project.description}</p>
            <ul>
                {project.tags.map(tag => (
                    <li>{tag}</li>
                ))}
            </ul>
            <img src={project.image} alt={`Screenshot of the project ${project.image}`}>
        </article>
    ))
}