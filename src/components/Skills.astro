      TAGS.PYTHON,
      TAGS.TYPESCRIPT,
      TAGS.JAVASCRIPT,
      TAGS.HTML,
      TAGS.CSS,
      TAGS.VBA,
      TAGS.SQL,
      TAGS.PLSQL,
      { ...TAGS.NEO4J, name: "Cypher" }
    ]
  },
  {
    category: "Frameworks",
    skills: [
      TAGS.FASTAPI,
      TAGS.DJANGO,
      TAGS.PANDAS,
      TAGS.POLARS,
      TAGS.SQLALCHEMY,
      TAGS.PYDANTIC,
      TAGS.BEAUTIFULSOUP,
      TAGS.ASTRO,
      TAGS.TAILWIND
    ]
  },
  {
    category: "Databases",
    skills: [
      TAGS.POSTGRESQL,
      TAGS.MYSQL,
      TAGS.SQLITE,
      TAGS.MONGODB,
      TAGS.REDIS,
      TAGS.NEO4J
    ]
  },
  {
